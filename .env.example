cat > .env.example << 'EOF'
# Database
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/git_arch?sslmode=require

# Auth
JWT_SECRET=minimum-32-character-secret-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI
GEMINI_API_KEY=
GROQ_API_KEY=

# Upstash Redis
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Service URLs (for api-gateway)
AUTH_URL=http://localhost:3001
INGESTION_URL=http://localhost:3002
RETRIEVAL_URL=http://localhost:3003
LLM_URL=http://localhost:3004
EOF